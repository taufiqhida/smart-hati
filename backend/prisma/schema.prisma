// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =============================================
// SMART HATI - Sistem Monitoring Hipertensi
// =============================================

enum Role {
  patient
  nurse
  doctor
  admin
}

enum Gender {
  male
  female
}

enum StressLevel {
  low
  medium
  high
}

enum BloodPressureClassification {
  normal
  prehypertension
  hypertension_1
  hypertension_2
  crisis
}

enum InputBy {
  patient
  nurse
}

enum RecommendationType {
  medication
  exercise
  diet
  stress_management
}

enum ReminderType {
  medication
  checkup
  blood_pressure_input
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  very_active
}

// User Model - All actors (patient, nurse, doctor, admin)
model User {
  id        Int      @id @default(autoincrement())
  nik       String   @unique @db.VarChar(16)
  name      String   @db.VarChar(100)
  email     String?  @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      Role     @default(patient)
  phone     String?  @db.VarChar(20)
  birthDate DateTime? @db.Date
  gender    Gender?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile              PatientProfile?
  bloodPressureRecords BloodPressureRecord[] @relation("PatientRecords")
  nurseRecords         BloodPressureRecord[] @relation("NurseRecords")
  receivedRecommendations Recommendation[]   @relation("PatientRecommendations")
  givenRecommendations    Recommendation[]   @relation("DoctorRecommendations")
  receivedPrescriptions   Prescription[]     @relation("PatientPrescriptions")
  givenPrescriptions      Prescription[]     @relation("DoctorPrescriptions")
  sentMessages         ChatMessage[]         @relation("SentMessages")
  receivedMessages     ChatMessage[]         @relation("ReceivedMessages")
  reminders            Reminder[]
  notifications        Notification[]
  dailyLifestyles      DailyLifestyle[]

  @@map("users")
}

// Patient Profile - Extended patient data
model PatientProfile {
  id               Int         @id @default(autoincrement())
  userId           Int         @unique
  age              Int?
  weight           Decimal?    @db.Decimal(5, 2)
  height           Decimal?    @db.Decimal(5, 2)
  hereditaryHistory Json?      // Riwayat keturunan hipertensi
  comorbidities    Json?       // Penyakit penyerta
  lifestyle        Json?       // Gaya hidup
  stressLevel      StressLevel @default(low)
  dietPattern      String?     @db.Text
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

// Blood Pressure Record
model BloodPressureRecord {
  id             Int                        @id @default(autoincrement())
  patientId      Int
  systolic       Int
  diastolic      Int
  pulse          Int?
  classification BloodPressureClassification
  inputBy        InputBy                    @default(patient)
  nurseId        Int?
  notes          String?                    @db.Text
  recordedAt     DateTime                   @default(now())
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  // Relations
  patient User  @relation("PatientRecords", fields: [patientId], references: [id], onDelete: Cascade)
  nurse   User? @relation("NurseRecords", fields: [nurseId], references: [id])

  @@map("blood_pressure_records")
}

// Recommendation by Doctor
model Recommendation {
  id          Int                @id @default(autoincrement())
  patientId   Int
  doctorId    Int
  type        RecommendationType
  title       String             @db.VarChar(200)
  description String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  patient User @relation("PatientRecommendations", fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User @relation("DoctorRecommendations", fields: [doctorId], references: [id])

  @@map("recommendations")
}

// Digital Prescription
model Prescription {
  id             Int      @id @default(autoincrement())
  patientId      Int
  doctorId       Int
  medicationName String   @db.VarChar(200)
  dosage         String   @db.VarChar(100)
  frequency      String   @db.VarChar(100)
  duration       String?  @db.VarChar(100)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  patient User @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User @relation("DoctorPrescriptions", fields: [doctorId], references: [id])

  @@map("prescriptions")
}

// Chat Messages for Live Consultation
model ChatMessage {
  id          Int       @id @default(autoincrement())
  senderId    Int
  receiverId  Int
  message     String    @db.Text
  isEmergency Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// Reminder for Medication, Checkup, etc.
model Reminder {
  id          Int          @id @default(autoincrement())
  patientId   Int
  type        ReminderType
  title       String       @db.VarChar(200)
  description String?      @db.Text 
  scheduledAt DateTime
  isCompleted Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  patient User @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("reminders")
}

// Notification
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  message   String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// Daily Lifestyle Record - Makanan, Stress, Aktivitas
model DailyLifestyle {
  id              Int           @id @default(autoincrement())
  patientId       Int
  date            DateTime      @db.Date
  
  // Makanan keseharian
  breakfast       String?       @db.Text
  lunch           String?       @db.Text
  dinner          String?       @db.Text
  snacks          String?       @db.Text
  waterIntake     Int?
  
  // Tingkat stress
  stressLevel     StressLevel   @default(low)
  stressNotes     String?       @db.Text
  
  // Aktivitas keseharian
  activityLevel   ActivityLevel @default(sedentary)
  activities      String?       @db.Text
  exerciseMinutes Int?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  patient         User          @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, date])
  @@map("daily_lifestyles")
}
